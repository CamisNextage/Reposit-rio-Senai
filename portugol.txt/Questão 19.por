programa {
  funcao inicio() {
   inteiro tes1, tes2, tes3, media
   escreva("Digite o primeiro número :")
   leia (tes1)

   escreva("Digite o segundo número :")
   leia(tes2)

   escreva("Digiite o terceiro número :")
   leia(tes3)

media <- tes1 + tes2 + tes3 /3
se (tes1 >= tes2 ) 
escreva("Operador de ouro")

senao
escreva("Reciclagem")
    
  }
}
