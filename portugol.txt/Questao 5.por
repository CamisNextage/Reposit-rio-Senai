programa {
  funcao inicio() {
   inteiro mediaConsumokWh, maquina1,maquina2,maquina3
   escreva("Digite um número :")
   leia(maquina1)
   escreva("Digite o segundo numero :")
   leia(maquina2)
   escreva("Digite o terceiro numero para darmos a média :")
   leia(maquina3)
   mediaConsumokWh= (maquina1+ maquina2 + maquina3) / 3
  escreva("A média é :", mediaConsumokWh) 
  }
}
