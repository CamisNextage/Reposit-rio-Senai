programa
{
    funcao inicio()
    {
        inteiro id

        escreva("Digite o ID da peça: ")
        leia(id)

        se (id % 2 == 0)
        {
            escreva("A peça deve seguir para a esteira esquerda.")
        }
        senao
        {
            escreva("A peça deve seguir para a esteira direita.")
        }
    }
}
  }
}
