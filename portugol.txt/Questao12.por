 programa
{
    funcao inicio()
    {
        inteiro idade

        escreva("Digite sua idade: ")
        leia(idade)

        se (idade >= 18)
        {
            escreva("Você é maior de idade. AUTORIZADO!")
        }
        senao
        {
            escreva("Você é menor de idade e não tem permissão para operar a máquina.NÃO AUTORIZADO!")
        }
    }
}
  }
}
