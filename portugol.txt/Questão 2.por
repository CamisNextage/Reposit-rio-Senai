programa {
  funcao inicio() {
     inteiro remessa1, remessa2, estoqueTotal
     escreva("Digite o número que deseja saber no estoque:")
     leia(remessa1)
     escreva("Digite o próximo número que deseja saber :")
     leia(remessa2)
     estoqueTotal= remessa1 + remessa2
     escreva("Este é o valor disponivel no estoque :", estoqueTotal)

  }
}
